rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // siteSettings: leitura pública (site). Escrita só para admin.
    //
    // O erro "Missing or insufficient permissions" quase sempre é:
    //   1) Regras ainda não publicadas → rode: firebase deploy --only firestore:rules
    //   2) E-mail do login em /admin diferente do e-mail abaixo → ajuste a string
    //   3) Ou use o UID (Authentication → Usuários → copiar "ID do usuário") na segunda linha
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'brunosouzagithub2003@gmail.com' ||
        request.auth.uid == 'oBUkVdqvJETOchTG6LyIiDzkNeG3'
      );
    }

    // CMS do portfólio: leitura pública; escrita só admin (mesmo critério que siteSettings).
    match /courses/{docId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'brunosouzagithub2003@gmail.com' ||
        request.auth.uid == 'oBUkVdqvJETOchTG6LyIiDzkNeG3'
      );
    }

    match /certificates/{docId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'brunosouzagithub2003@gmail.com' ||
        request.auth.uid == 'oBUkVdqvJETOchTG6LyIiDzkNeG3'
      );
    }

    match /projects/{docId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'brunosouzagithub2003@gmail.com' ||
        request.auth.uid == 'oBUkVdqvJETOchTG6LyIiDzkNeG3'
      );
    }
  }
}
