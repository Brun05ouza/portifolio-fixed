# Usuário do GitHub (padrão: Brun05ouza)
VITE_GITHUB_USER=Brun05ouza

# Token do GitHub para evitar rate limit (opcional)
# VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Firebase – formulário de contato (mensagens salvas na coleção "contacts")
# Obtenha em: Firebase Console > Project settings > General > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# EmailJS – envio de e-mail para você (plano gratuito, sem Cloud Functions)
# Crie conta em https://www.emailjs.com/ e configure um Email Service + Template
# No template use: {{from_name}}, {{reply_to}}, {{message}}. Defina o "To" como seu e-mail.
# VITE_EMAILJS_PUBLIC_KEY=
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=

# WhatsApp – número internacional sem + (ex: 5521999999999). Usado pelo botão "Solicitar orçamento" e flutuante.
# VITE_WHATSAPP_NUMBER=5521999999999

# Calendly – URL da sua página de agendamento (ex: https://calendly.com/seu-usuario/30min)
# VITE_CALENDLY_URL=https://calendly.com/SEU_LINK_AQUI
